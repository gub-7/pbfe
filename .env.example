# ─────────────────────────────────────────────────────
# BrickedUp Backend Configuration
# ─────────────────────────────────────────────────────

# OpenAI API key — required for multi-view image generation
OPENAI_API_KEY=sk-your-key-here

# Image generation model
IMAGE_GEN_MODEL=gpt-image-1

# GPU Cluster service URL (image → 3D reconstruction)
# For local testing: http://localhost:8001
# For DigitalOcean GPU: https://your-gpu-droplet.example.com
GPU_CLUSTER_URL=http://gpu-cluster:8001

# Rubric service URL (3D → LEGO conversion)
RUBRIC_URL=http://rubric:8002

# Local data storage directory
DATA_DIR=data

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

